<?xml version="1.0" encoding="UTF-8"?>
<phpunit bootstrap="tests/phpunit/bootstrap.php"
         colors="true"
         failOnRisky="true"
         failOnWarning="true">
    <testsuites>
        <testsuite name="Home Inference">
            <directory>tests/phpunit</directory>
        </testsuite>
    </testsuites>
</phpunit>
