{
  "name": "@mattwiebe/wp-home-inference",
  "version": "0.1.4",
  "description": "CLI and WordPress plugin for routing AI inference to models running on your own machine.",
  "type": "module",
  "bin": {
    "wph": "bin/wp-home-inference.mjs",
    "wphi": "bin/wp-home-inference.mjs",
    "wp-home-inference": "bin/wp-home-inference.mjs"
  },
  "files": [
    "bin/wp-home-inference.mjs",
    "local/server.mjs",
    "scripts/launch-agent.mjs",
    "README.md"
  ],
  "scripts": {
    "up": "node local/server.mjs",
    "init": "node local/server.mjs init",
    "start": "node scripts/launch-agent.mjs start",
    "stop": "node scripts/launch-agent.mjs stop",
    "status": "node scripts/launch-agent.mjs status",
    "rotate-key": "node scripts/launch-agent.mjs rotate-key",
    "service:install": "node scripts/launch-agent.mjs install",
    "service:uninstall": "node scripts/launch-agent.mjs uninstall",
    "lint": "node --check bin/wp-home-inference.mjs && node --check local/server.mjs && node --check scripts/launch-agent.mjs && node --check scripts/release.mjs",
    "test": "node --test",
    "build": "npm run build:plugin && npm run build:npm",
    "release": "node scripts/release.mjs",
    "build:plugin": "bash scripts/build-plugin-zip.sh",
    "build:npm": "bash scripts/build-npm-tarball.sh",
    "publish:npm": "npm publish",
    "prepublishOnly": "npm run lint && npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattwiebe/wp-home-inference.git"
  },
  "bugs": {
    "url": "https://github.com/mattwiebe/wp-home-inference/issues"
  },
  "homepage": "https://github.com/mattwiebe/wp-home-inference#readme",
  "license": "GPL-2.0-or-later",
  "engines": {
    "node": ">=20"
  }
}
