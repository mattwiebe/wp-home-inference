{
  "name": "@mattwiebe/ai-connector-for-local-ai",
  "version": "0.4.1",
  "description": "CLI and WordPress plugin for routing AI inference to models running on your own machine.",
  "type": "module",
  "bin": {
    "laiproxy": "bin/mw-local-ai-connector.mjs",
    "mw-local-ai-connector": "bin/mw-local-ai-connector.mjs"
  },
  "files": [
    "bin/mw-local-ai-connector.mjs",
    "local/server.mjs",
    "scripts/launch-agent.mjs",
    "README.md"
  ],
  "scripts": {
    "up": "node local/server.mjs",
    "init": "node local/server.mjs init",
    "start": "node scripts/launch-agent.mjs start",
    "stop": "node scripts/launch-agent.mjs stop",
    "status": "node scripts/launch-agent.mjs status",
    "rotate-key": "node scripts/launch-agent.mjs rotate-key",
    "service:install": "node scripts/launch-agent.mjs install",
    "service:uninstall": "node scripts/launch-agent.mjs uninstall",
    "lint": "node --check bin/mw-local-ai-connector.mjs && node --check local/server.mjs && node --check scripts/launch-agent.mjs && node --check scripts/release.mjs",
    "test": "node --test",
    "build": "npm run build:plugin && npm run build:npm",
    "release": "node scripts/release.mjs",
    "build:plugin": "bash scripts/build-plugin-zip.sh",
    "build:npm": "bash scripts/build-npm-tarball.sh",
    "publish:npm": "npm publish",
    "prepublishOnly": "npm run lint && npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattwiebe/ai-connector-for-local-ai.git"
  },
  "bugs": {
    "url": "https://github.com/mattwiebe/ai-connector-for-local-ai/issues"
  },
  "homepage": "https://github.com/mattwiebe/ai-connector-for-local-ai#readme",
  "license": "GPL-2.0-or-later",
  "engines": {
    "node": ">=20"
  }
}
