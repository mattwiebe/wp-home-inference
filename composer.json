{
    "name": "mattwiebe/mw-local-ai-connector",
    "description": "WordPress AI provider plugin and local proxy for self-hosted inference.",
    "type": "wordpress-plugin",
    "keywords": [
        "wordpress",
        "wordpress-plugin",
        "ai",
        "connectors",
        "tailscale",
        "inference"
    ],
    "homepage": "https://github.com/mattwiebe/mw-local-ai-connector",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Matt Wiebe",
            "homepage": "https://github.com/mattwiebe"
        }
    ],
    "support": {
        "issues": "https://github.com/mattwiebe/mw-local-ai-connector/issues",
        "source": "https://github.com/mattwiebe/mw-local-ai-connector",
        "docs": "https://github.com/mattwiebe/mw-local-ai-connector#readme"
    },
    "require": {
        "php": "^7.4 || ^8.0"
    },
    "autoload": {
        "files": [
            "src/autoload.php"
        ]
    },
    "extra": {
        "installer-name": "mw-local-ai-connector",
        "branch-alias": {
            "dev-main": "0.2.x-dev"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^4.0"
    },
    "scripts": {
        "lint": [
            "php -l mw-local-ai-connector.php",
            "find bin -name '*.sh' -print0 | xargs -0 -n1 bash -n",
            "find src tests/phpunit -name '*.php' -print0 | xargs -0 -n1 php -l"
        ],
        "test:install-wp": "bash bin/install-wp-tests.sh wordpress_test root root 127.0.0.1 latest true",
        "test": "phpunit --configuration phpunit.xml.dist"
    }
}
